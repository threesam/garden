# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# sveltekit
/.svelte-kit/
/build

# production
/out

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# financial data
data/finance/

# vercel
.vercel

# typescript
*.tsbuildinfo

# git worktrees
.worktrees/

# leftovers from the Next.js era + agent-session artifacts — never commit.
# (a stray `git add -A` once swept 6,475 of these into a feature commit.)
/.next/
next-env.d.ts
/.claude/
/.playwright-mcp/
/.superset/
/test-results/

# large media imports
static/assets/messages/
data/messages/dianchik/conversation.json
data/messages/dianchik/combined.json
data/messages/dianchik/imessage.json

# personal notes
content/notes/

# sounds — local-first source material + generated audio (manifest is committed)
/sc-inventory/
# Audio bytes stay on R2; we ignore EVERYTHING under static/audio/sounds…
/static/audio/sounds/*
# …EXCEPT the pre-optimized cover webps (generated by
# scripts/optimize-sound-covers.mjs) — they replace ~10 MB of unoptimized R2
# jpegs at ~1 MB total and are deterministic from the manifest. Note: git
# can't un-ignore a child when the parent dir is excluded, hence the
# `/sounds/*` (files-only) form above.
!/static/audio/sounds/covers/
lh-triage.json

# agent-session artifacts
.claude/
.superset/
.playwright-mcp/

# Next-era leftovers (never part of the SvelteKit build)
.next/
next-env.d.ts
package/
public/
.worktrees/
